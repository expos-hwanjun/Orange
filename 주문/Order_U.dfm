  object UniQuery: TUniQuery
    SQL.Strings = (
      'select t1.cd_menu, '
      '       t1.nm_menu, '
      '       t1.nm_menu_short,'
      '       t1.ds_menu_type as ds_menu, '
      
        '       case when (t1.yn_scale = '#39'Y'#39') and (t1.ds_menu_type='#39'W'#39') t' +
        'hen isnull(t1.pr_balance,0) else isnull(t1.pr_sale,0) end as pr_' +
        'sale,'
      '       t1.pr_sale_double, '
      '       t1.pr_tip, '
      '       t1.pr_sale - t2.pr_sale as dc_spc, '
      '       case when t2.cd_menu is null then '#39#39' '
      #9'           else t2.no_spc  '
      '       end as no_spc, '
      '       t1.pr_wonga, '
      '       t1.ds_tax, '
      '       t1.qty_select, '
      '       t1.cd_printer, '
      '       t1.yn_dc, '
      '       t1.yn_point, '
      '       t1.yn_rcp, '
      '       t1.no_van, '
      '       t1.ds_kitchen, '
      '       t1.no_group, '
      '       t1.cd_class, '
      
        '       case when (:p4 = '#39'Y'#39') and (t1.yn_pincode = '#39'Y'#39')  then dbo' +
        '.GetMenuPinCode(t1.cd_store, t1.cd_menu) else '#39#39' end as meat_pin' +
        'code, '
      '       t1.yn_okc, '
      '       t1.yn_scale, '
      '       t1.cd_corner, '
      '       t1.yn_person, '
      '       t1.yn_pincode,'
      '       t1.pr_buy,'
      '       t1.pr_sale_profit,'
      '       t1.yn_bill,'
      '       t1.yn_ticket,'
      '       t1.save_stamp,'
      '       t1.use_stamp,'
      '       t1.ds_item'
      '  from ms_menu t1 left outer join '
      '       ( select Max(b.no_spc) as no_spc,'
      '                a.cd_menu, '
      '                a.pr_sale'
      #9'   from ms_spc_d a inner join  '
      '                ms_spc_h b on a.cd_store   = b.cd_store '
      '                          and a.no_spc     = b.no_spc '
      '          where a.cd_store   = :p0  '
      '            and b.ds_spc     = '#39'0'#39
      '            and b.dt_from   <= :p2 '
      '            and b.dt_to     >= :p2 '
      '            and b.time_from <= :p3 '
      '            and b.time_to   >= :p3 '
      '            and dbo.get_spc_weekly(b.weekly, getdate())  = '#39'1'#39
      '            and b.yn_use    = '#39'0'#39
      '            and a.yn_use    = '#39'Y'#39
      '          group by a.cd_menu, a.pr_sale'
      '        ) t2 on t1.cd_menu = t2.cd_menu'
      'where t1.cd_store  = :p0 '
      '    and t1.cd_menu = :p1 '
      '    and t1.yn_use = '#39'Y'#39)
    FetchRows = 1
    UniDirectional = True
    Left = 256
    Top = 216
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'p4'
        Value = nil
      end
      item
        DataType = ftString
        Name = 'p0'
        ParamType = ptInput
        Value = nil
      end
      item
        DataType = ftString
        Name = 'p2'
        ParamType = ptInput
        Value = nil
      end
      item
        DataType = ftString
        Name = 'p3'
        ParamType = ptInput
        Value = nil
      end
      item
        DataType = ftString
        Name = 'p1'
        ParamType = ptInput
        Value = nil
      end>
  end
