  object OpenDialog1: TOpenDialog
    Filter = '*.avi|*.avi|*.jpg|*.jpg'
    Options = [ofReadOnly, ofOverwritePrompt, ofHideReadOnly, ofNoChangeDir, ofEnableSizing]
    Left = 368
    Top = 25
  end
end
