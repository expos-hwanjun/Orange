  object Script: TUniScript
    SQL.Strings = (
      'DROP TABLE IF EXISTS `temp_letsorder`;'
      'CREATE TABLE IF NOT EXISTS `temp_letsorder` ('
      '  `IDX` bigint(20) NOT NULL AUTO_INCREMENT,'
      '  `QUEUE_MSG` longtext DEFAULT NULL,'
      '  `DT_INSERT` datetime DEFAULT current_timestamp(),'
      '  PRIMARY KEY (`IDX`)'
      
        ') ENGINE=InnoDB AUTO_INCREMENT=96 DEFAULT CHARSET=utf8 COMMENT='#39 +
        #47112#52768#50724#45908' '#49688#49888#45236#50669#39';'
      ''
      ''
      'DROP PROCEDURE IF EXISTS `POS_SAVE_ORDER_D`;'
      'DELIMITER //'
      'CREATE PROCEDURE `POS_SAVE_ORDER_D`('
      '   IN `_CD_STORE` VARCHAR(8),'
      '   IN `_NO_TABLE` INT,'
      '   IN `_DS_ORDER` VARCHAR(1),'
      '   IN `_CD_MENU` VARCHAR(100),'
      '   INOUT `_SEQ` INT,'
      '   IN `_NO_STEP` INT,'
      '   IN `_NO_POS` VARCHAR(2),'
      '   IN `_DS_SALE` VARCHAR(1),'
      '   IN `_NM_MENU` VARCHAR(50),'
      '   IN `_DS_MENU` VARCHAR(1),'
      '   IN `_CD_MENU1` VARCHAR(14),'
      '   IN `_PR_SALE` INT,'
      '   IN `_QTY_ORDER` INT,'
      '   IN `_AMT_ORDER` INT,'
      '   IN `_PR_SALE_ORG` INT,'
      '   IN `_PR_TIP` INT,'
      '   IN `_PR_ITEM` INT,'
      '   IN `_CD_ITEM` VARCHAR(100),'
      '   IN `_QTY_NEPUM` INT,'
      '   IN `_DS_TAX` VARCHAR(1),'
      '   IN `_CD_PRINTER` VARCHAR(100),'
      '   IN `_NO_SPC` VARCHAR(4),'
      '   IN `_DC_SPC` INT,'
      '   IN `_DC_MENU` INT,'
      '   IN `_MEMO` VARCHAR(30),'
      '   IN `_YN_DOUBLE` VARCHAR(1),'
      '   IN `_CD_SERVICE` VARCHAR(3),'
      '   IN `_NO_ORDER` VARCHAR(10),'
      '   IN `_WORK_KIND` VARCHAR(1),'
      '   OUT `_RESULT_SEQ` INT'
      ')'
      'proc_body:'
      'BEGIN'
      '  DECLARE _CNT        INT;'
      '  DECLARE _SEQ1       INT;  '
      '  DECLARE _MAXSEQ     INT;'
      ''
      '  '
      '  '
      '  SET _RESULT_SEQ = -1;'
      '  if _WORK_KIND = '#39'I'#39' then'
      '    if _DS_MENU IN ('#39'C'#39', '#39'O'#39','#39'I'#39') then'
      '       if _CD_MENU1 = '#39#39' then'
      '         select Ifnull(SEQ,-1) into _RESULT_SEQ'
      '           from SL_ORDER_D'
      '          where CD_STORE   =_CD_STORE'
      '            and NO_TABLE   =_NO_TABLE'
      '            and DS_ORDER   =_DS_ORDER'
      '            and CD_MENU    =_CD_MENU   '
      '            AND CD_MENU1   ='#39#39
      '            and CD_ITEM    =_CD_ITEM;'
      '            '
      '           '
      '         if _RESULT_SEQ >= 0 then'
      '            update SL_ORDER_D '
      '               set QTY_ORDER  = QTY_ORDER + _QTY_ORDER,'
      '                   AMT_ORDER  = (PR_SALE+PR_ITEM) * _QTY_ORDER,'
      '                   NO_ORDER   = _NO_ORDER,'
      '                   YN_LETSORDER = '#39'N'#39','
      '                   DT_CHANGE      = NOW()'
      '             where CD_STORE       =_CD_STORE'
      '                   AND NO_TABLE   =_NO_TABLE'
      '                   AND DS_ORDER   =_DS_ORDER'
      '                   AND CD_MENU    =_CD_MENU'
      '                   AND SEQ        =_RESULT_SEQ;'
      '                   '
      '           SET _SEQ = _RESULT_SEQ;    '
      '           leave proc_body;    '
      '         else  '
      '           select IFNULL(MAX(SEQ),0)+1 into _SEQ'
      '             from SL_ORDER_D'
      '            where CD_STORE   =_CD_STORE'
      '              and NO_TABLE   =_NO_TABLE'
      '              and DS_ORDER   =_DS_ORDER;'
      '         end if;'
      '       end if;'
      ''
      '    insert into SL_ORDER_D(CD_STORE,'
      '                            NO_TABLE,'
      '                            DS_ORDER,'
      '                            CD_MENU,'
      '                            SEQ,'
      '                            NO_STEP,'
      '                            NO_POS,'
      '                            DS_SALE,'
      '                            NM_MENU,'
      '                            CD_MENU1,'
      '                            DS_MENU_TYPE,'
      '                            PR_SALE,'
      '                            QTY_ORDER,'
      '                            AMT_ORDER,'
      '                            PR_SALE_ORG,'
      '                            PR_TIP,'
      '                            PR_ITEM,'
      '                            CD_ITEM,'
      '                            QTY_NEPUM,'
      '                            DS_TAX,'
      '                            CD_PRINTER,'
      '                            NO_SPC,'
      '                            DC_SPC,'
      '                            DC_MENU,'
      '                            MEMO,'
      '                            YN_DOUBLE,'
      '                            CD_SERVICE,'
      '                            NO_ORDER,'
      '                            YN_LETSORDER,'
      '                            DT_INSERT,'
      '                            DT_CHANGE)'
      '                    VALUES( _CD_STORE,'
      '                            _NO_TABLE,'
      '                            _DS_ORDER,'
      '                            _CD_MENU,'
      '                            _SEQ,'
      '                            _NO_STEP,'
      '                            _NO_POS,'
      '                            _DS_SALE,'
      '                            _NM_MENU,'
      '                            _CD_MENU1,'
      '                            _DS_MENU,'
      '                            _PR_SALE,'
      '                            _QTY_ORDER,'
      '                            _AMT_ORDER,'
      '                            _PR_SALE_ORG,'
      '                            _PR_TIP,'
      '                            _PR_ITEM,'
      '                            _CD_ITEM,'
      '                            _QTY_NEPUM,'
      '                            _DS_TAX,'
      '                            _CD_PRINTER,'
      '                            _NO_SPC,'
      '                            _DC_SPC,'
      '                            _DC_MENU,'
      '                            _MEMO,'
      '                            _YN_DOUBLE,'
      '                            _CD_SERVICE,'
      '                            _NO_ORDER,'
      '                            '#39'N'#39','
      '                            NOW(),'
      '                            NOW());'
      '    '
      '    else'
      '      if _DS_MENU = '#39'W'#39' then'
      '        SET _CNT = 0;'
      '        '
      '        select IFNULL(MAX(SEQ),0)+1 into _SEQ'
      '          from SL_ORDER_D'
      '         where CD_STORE   =_CD_STORE'
      '           and NO_TABLE   =_NO_TABLE'
      '           and DS_ORDER   =_DS_ORDER;   '
      '      else'
      '        select COUNT(*) into _SEQ1'
      '          from SL_ORDER_D'
      '         where CD_STORE   =_CD_STORE'
      '           and NO_TABLE   =_NO_TABLE'
      '           and DS_ORDER   =_DS_ORDER'
      '           and SEQ        =_SEQ'
      '           and NO_STEP    =_NO_STEP;'
      ''
      '        select IFNULL(MAX(SEQ),0)+1 into _MAXSEQ'
      '          from SL_ORDER_D                                '
      '         where CD_STORE   =_CD_STORE'
      '           and NO_TABLE   =_NO_TABLE'
      '           and DS_ORDER   =_DS_ORDER;   '
      ''
      ''
      '        select COUNT(*) into _CNT'
      '          from SL_ORDER_D'
      '         where CD_STORE   =_CD_STORE'
      '           and NO_TABLE   =_NO_TABLE'
      '           and DS_ORDER   =_DS_ORDER'
      '           and CD_MENU    =_CD_MENU    '
      '           and CD_MENU1   =_CD_MENU1   '
      '           and DS_SALE    =_DS_SALE'
      '           and PR_SALE    =_PR_SALE'
      '           and MEMO       =_MEMO'
      '           and CD_ITEM    =_CD_ITEM'
      '           and CD_SERVICE =_CD_SERVICE;'
      '      end if;'
      '          '
      '  '
      '      if _CNT = 0 then'
      '        if _SEQ1 = 1 then'
      '          SET _SEQ  = Ifnull(_MAXSEQ,1);'
      '        end if;'
      '        '
      '        INSERT INTO SL_ORDER_D(CD_STORE,'
      '                               NO_TABLE,'
      '                               DS_ORDER,'
      '                               CD_MENU,'
      '                               SEQ,'
      '                               NO_STEP,'
      '                               NO_POS,'
      '                               DS_SALE,'
      '                               NM_MENU,'
      '                               CD_MENU1,'
      '                               DS_MENU_TYPE,'
      '                               PR_SALE,'
      '                               QTY_ORDER,'
      '                               AMT_ORDER,'
      '                               PR_SALE_ORG,'
      '                               PR_TIP,'
      '                               PR_ITEM,'
      '                               CD_ITEM,'
      '                               QTY_NEPUM,'
      '                               DS_TAX,'
      '                               CD_PRINTER,'
      '                               NO_SPC,'
      '                               DC_SPC,'
      '                               DC_MENU,'
      '                               MEMO,'
      '                               YN_DOUBLE,'
      '                               CD_SERVICE,'
      '                               NO_ORDER,'
      '                               YN_LETSORDER,'
      '                               DT_INSERT,'
      '                               DT_CHANGE)'
      '                      VALUES  (_CD_STORE,'
      '                               _NO_TABLE,'
      '                               _DS_ORDER,'
      '                               _CD_MENU,'
      '                               _SEQ,'
      '                               _NO_STEP,'
      '                               _NO_POS,'
      '                               _DS_SALE,'
      '                               _NM_MENU,'
      '                               _CD_MENU1,'
      '                               _DS_MENU,'
      '                               _PR_SALE,'
      '                               _QTY_ORDER,'
      '                               _AMT_ORDER,'
      '                               _PR_SALE_ORG,'
      '                               _PR_TIP,'
      '                               _PR_ITEM,'
      '                               _CD_ITEM,'
      '                               _QTY_NEPUM,'
      '                               _DS_TAX,'
      '                               _CD_PRINTER,'
      '                               _NO_SPC,'
      '                               _DC_SPC,'
      '                               _DC_MENU,'
      '                               _MEMO,'
      '                               _YN_DOUBLE,'
      '                               _CD_SERVICE,'
      '                               _NO_ORDER,'
      '                               '#39'N'#39','
      '                               Now(),'
      '                               Now());'
      '      else'
      '        update SL_ORDER_D '
      '           set QTY_ORDER  = QTY_ORDER + _QTY_ORDER,'
      
        '               AMT_ORDER  = (PR_SALE * _QTY_ORDER) + (PR_ITEM * ' +
        '_QTY_ORDER),'
      '               NO_ORDER   = _NO_ORDER,'
      '               YN_LETSORDER = '#39'N'#39','
      '               DT_CHANGE      = NOW()'
      '         where CD_STORE       =_CD_STORE'
      '               AND NO_TABLE   =_NO_TABLE'
      '               AND DS_ORDER   =_DS_ORDER'
      '               AND CD_MENU    =_CD_MENU'
      '               AND CD_MENU1   =_CD_MENU1'
      '               AND DS_SALE    =_DS_SALE'
      '               AND PR_SALE    =_PR_SALE'
      '               AND MEMO       =_MEMO'
      '               AND CD_ITEM    =_CD_ITEM'
      '               AND CD_SERVICE =_CD_SERVICE;'
      '      end if;'
      '    end if;'
      '  else'
      '    update  SL_ORDER_D '
      '       set  DS_SALE     =_DS_SALE,'
      '            PR_SALE     =_PR_SALE,'
      '            AMT_ORDER   =_AMT_ORDER,'
      '            PR_TIP      =_PR_TIP,'
      '            PR_ITEM     =_PR_ITEM,'
      '            DC_MENU     =_DC_MENU,'
      '            YN_DOUBLE   =_YN_DOUBLE,'
      '            CD_SERVICE  =_CD_SERVICE,'
      '            NO_ORDER    =_NO_ORDER,'
      '            YN_LETSORDER = '#39'N'#39','
      '            DT_CHANGE   =NOW()'
      '     where  CD_STORE   =_CD_STORE'
      '       and  NO_TABLE   =_NO_TABLE'
      '       and  DS_ORDER   =_DS_ORDER'
      '       and  SEQ        =_SEQ'
      '       and  NO_STEP    =_NO_STEP;'
      '  end if;                            '
      ''
      'END//'
      'DELIMITER ;'
      ''
      '-- '#53944#47532#44144' orangepos.TR_SL_ORDER_D_DELETE '#44396#51312' '#45236#48372#45236#44592
      'DROP TRIGGER IF EXISTS `TR_SL_ORDER_D_DELETE`;'
      
        'SET @OLDTMP_SQL_MODE=@@SQL_MODE, SQL_MODE='#39'NO_AUTO_CREATE_USER,N' +
        'O_ENGINE_SUBSTITUTION'#39';'
      'DELIMITER //'
      
        'CREATE TRIGGER `TR_SL_ORDER_D_DELETE` BEFORE DELETE ON `sl_order' +
        '_d` FOR EACH ROW trigger_body:'
      'BEGIN'
      '  DECLARE _OPTION9    VARCHAR(1);'
      '  DECLARE _GROUP_SEQ  INT;  '
      '  DECLARE _TABLE_COUNT INT;'
      '  '
      '  if OLD.CD_STORE IN ('#39'CASHTEMP'#39','#39'9999'#39') then'
      '     leave trigger_body; '
      '  END if;  '
      '  '
      '  SET time_zone ='#39'+9:00'#39';'
      '   '
      
        '  if (OLD.NO_STEP = 0) and (OLD.DS_ORDER = '#39'T'#39') AND (OLD.NO_TABL' +
        'E > 0) then'
      '    SELECT SUBSTRING(HEAD_OPTIONS, 9, 1) INTO _OPTION9'
      '      FROM MS_STORE'
      '     WHERE CD_STORE = OLD.CD_STORE;  '
      '     '
      '    SELECT COUNT(*) INTO _TABLE_COUNT'
      '      FROM SL_ORDER_H'
      '     WHERE CD_STORE = OLD.CD_STORE'
      '       AND DS_ORDER = OLD.DS_ORDER'
      '       AND NO_TABLE = OLD.NO_TABLE;    '
      '  '
      '    if (_OPTION9 = '#39'1'#39') AND (_TABLE_COUNT = 1) then  '
      '      SET  _GROUP_SEQ = GetNextVal('#39'TR_ORDER'#39');'
      '    '
      '      INSERT INTO TR_ORDER(CD_STORE,'
      '                           GROUP_SEQ,'
      '                           GROUP_STEP,'
      '                           DS_ORDER,'
      '                           NO_TABLE,'
      '                           SEQ,'
      '                           NO_STEP,'
      '                           CD_MENU,'
      '                           CD_MENU_SUB,'
      '                           QTY_ORDER,'
      '                           PR_ORDER,'
      '                           AMT_ORDER,'
      '                           CD_ITEMS,'
      '                           AMT_ITEM,'
      '                           DS_MENU_TYPE,'
      '                           NO_SPC,'
      '                           DC_SPC,'
      '                           DS_ORDER_TYPE,'
      '                           NO_ORDER)'
      '                    select CD_STORE,'
      '                           _GROUP_SEQ,        '
      '                           @ROWNUM:=@ROWNUM+1, '
      '                           '#39'C'#39','
      '                           NO_TABLE,'
      '                           SEQ,'
      '                           NO_STEP,'
      '                           CD_MENU,'
      '                           CD_MENU1,'
      '                           OLD.QTY_ORDER,'
      '                           PR_SALE,'
      '                           OLD.QTY_ORDER * PR_SALE,'
      '                           CD_ITEM,'
      '                           PR_ITEM,'
      '                           DS_MENU_TYPE,'
      '                           NO_SPC,'
      '                           DC_SPC,'
      '                           DS_SALE,'
      '                           NO_ORDER'
      '                     FROM SL_ORDER_D, (SELECT @ROWNUM:=0) AS R '
      '                    WHERE CD_STORE = OLD.CD_STORE'
      '                      AND NO_TABLE = OLD.NO_TABLE'
      '                      AND DS_ORDER = '#39'T'#39
      '                      AND SEQ      = OLD.SEQ;        '
      '    END if;                            '
      '  END if;'
      '  '
      '  if (OLD.DS_ORDER <> '#39'D'#39') AND (OLD.NO_STEP = 0) then'
      
        '    if EXISTS(SELECT * FROM SL_ORDER_H WHERE CD_STORE = OLD.CD_S' +
        'TORE AND NO_TABLE = OLD.NO_TABLE AND DS_ORDER = OLD.DS_ORDER) th' +
        'en'
      '      INSERT INTO SL_ORDER_HIST(CD_STORE,'
      '                                NO_TABLE,'
      '                                SEQ,'
      '                                DS_ORDER,  '
      '                                NO_POS,'
      '                                CD_MENU,'
      '                                QTY_ORDER,'
      '                                DT_ORDER,'
      '                                ORDER_REF,'
      '                                NO_ORDER)'
      '                        VALUES(OLD.CD_STORE,'
      '                               OLD.NO_TABLE,'
      '                               (SELECT Ifnull(MAX(SEQ),0)+1'
      '                                  FROM SL_ORDER_HIST s'
      '                                 WHERE CD_STORE  = OLD.CD_STORE'
      
        '                                   AND NO_TABLE  = OLD.NO_TABLE)' +
        ','
      
        '                               case when OLD.YN_LETSORDER = '#39'Y'#39' ' +
        'then '#39'L'#39' ELSE '#39'P'#39' END,'
      '                               OLD.NO_POS,'
      '                               OLD.CD_MENU,'
      '                               -OLD.QTY_ORDER,'
      '                               NOW(),'
      
        '                               CONCAT(OLD.DS_ORDER,'#39'|'#39',CAST(OLD.' +
        'SEQ AS CHAR)),'
      '                               OLD.NO_ORDER);'
      '    END if;                               '
      ''
      '  END if;  '
      
        '  INSERT INTO TEMP_SQL(SQL_TEXT) VALUES(CONCAT('#39'Call `SET_SOLDOU' +
        'T`('#39#39#39',OLD.CD_STORE,'#39#39#39','#39#39#39#39','#39#39#39',OLD.CD_MENU,'#39#39#39')'#39'));'
      'END//'
      'DELIMITER ;'
      'SET SQL_MODE=@OLDTMP_SQL_MODE;'
      ''
      '-- '#53944#47532#44144' orangepos.TR_SL_ORDER_D_INSERT '#44396#51312' '#45236#48372#45236#44592
      'DROP TRIGGER IF EXISTS `TR_SL_ORDER_D_INSERT`;'
      
        'SET @OLDTMP_SQL_MODE=@@SQL_MODE, SQL_MODE='#39'NO_AUTO_CREATE_USER,N' +
        'O_ENGINE_SUBSTITUTION'#39';'
      'DELIMITER //'
      
        'CREATE TRIGGER `TR_SL_ORDER_D_INSERT` AFTER INSERT ON `sl_order_' +
        'd` FOR EACH ROW trigger_body:'
      'BEGIN'
      '  DECLARE _OPTION9     VARCHAR(1);'
      '  DECLARE _OPTION15    VARCHAR(1);  '
      '  DECLARE _OPTION94    VARCHAR(1);'
      '  DECLARE _GROUP_SEQ  INT;'
      '  '
      '  if (NEW.CD_STORE IN ('#39'9999'#39','#39'CASHTEMP'#39')) then'
      '     leave trigger_body; '
      '  END if;  '
      '  '
      '  SET time_zone ='#39'+9:00'#39';'
      '  if (NEW.DS_ORDER = '#39'T'#39') AND (NEW.NO_TABLE > 0) then'
      '    SELECT SUBSTRING(HEAD_OPTIONS, 9, 1),'
      '           SUBSTRING(HEAD_OPTIONS, 15, 1),'
      
        '           SUBSTRING(OPTIONS, 94, 1) INTO _OPTION9, _OPTION15, _' +
        'OPTION94'
      '      FROM MS_STORE'
      '     WHERE CD_STORE = NEW.CD_STORE;  '
      '  '
      '    if (_OPTION15 = '#39'0'#39') AND (_OPTION9 = '#39'1'#39') then'
      '      if NEW.NO_STEP = 0 then'
      '         SET _GROUP_SEQ = GetNextVal('#39'TR_ORDER'#39');'
      '      ELSE'
      '        SET _GROUP_SEQ = GetLastVal('#39'TR_ORDER'#39');         '
      '      END if; '
      '           '
      '      INSERT INTO TR_ORDER(CD_STORE,'
      '                           GROUP_SEQ,'
      '                           GROUP_STEP,'
      '                           DS_ORDER,'
      '                           NO_TABLE,'
      '                           SEQ,'
      '                           NO_STEP,'
      '                           CD_MENU,'
      '                           CD_MENU_SUB,'
      '                           QTY_ORDER,'
      '                           PR_ORDER,'
      '                           AMT_ORDER,'
      '                           DS_MENU_TYPE,'
      '                           DS_ORDER_TYPE,'
      '                           ORDER_DEVICE,'
      '                           NO_ORDER)'
      '                    VALUES(NEW.CD_STORE,'
      '                           _GROUP_SEQ,         '
      '                           NEW.NO_STEP,'
      '                           '#39'O'#39','
      '                           NEW.NO_TABLE,'
      '                           NEW.SEQ,'
      '                           NEW.NO_STEP,'
      '                           NEW.CD_MENU,'
      '                           NEW.CD_MENU1,'
      '                           NEW.QTY_ORDER,'
      '                           NEW.PR_SALE,'
      '                           NEW.AMT_ORDER,'
      '                           NEW.DS_MENU_TYPE,'
      '                           NEW.DS_ORDER,'
      '                           NEW.YN_LETSORDER,'
      '                           NEW.NO_ORDER);'
      
        '    ELSEIF (_OPTION15 = '#39'1'#39') AND (_OPTION9 = '#39'1'#39') AND (_OPTION94' +
        ' IN ('#39'1'#39','#39'2'#39','#39'3'#39')) then'
      '      if NEW.NO_STEP = 0 then'
      '         SET _GROUP_SEQ = GetNextVal('#39'TR_ORDER'#39');'
      '      ELSE'
      '        SET _GROUP_SEQ = GetLastVal('#39'TR_ORDER'#39');         '
      '      END if; '
      '           '
      '      INSERT INTO TR_ORDER(CD_STORE,'
      '                           GROUP_SEQ,'
      '                           GROUP_STEP,'
      '                           DS_ORDER,'
      '                           NO_TABLE,'
      '                           SEQ,'
      '                           NO_STEP,'
      '                           CD_MENU,'
      '                           CD_MENU_SUB,'
      '                           QTY_ORDER,'
      '                           PR_ORDER,'
      '                           AMT_ORDER,'
      '                           DS_MENU_TYPE,'
      '                           DS_ORDER_TYPE,'
      '                           ORDER_DEVICE,'
      '                           NO_ORDER)'
      '                    VALUES(NEW.CD_STORE,'
      '                           _GROUP_SEQ,         '
      '                           NEW.NO_STEP,'
      '                           '#39'O'#39','
      '                           NEW.NO_TABLE,'
      '                           NEW.SEQ,'
      '                           NEW.NO_STEP,'
      '                           NEW.CD_MENU,'
      '                           NEW.CD_MENU1,'
      '                           NEW.QTY_ORDER,'
      '                           NEW.PR_SALE,'
      '                           NEW.AMT_ORDER,'
      
        '                           NEW.DS_MENU_TYPE,                    ' +
        '       '
      '                           NEW.DS_MENU_TYPE,'
      '                           NEW.YN_LETSORDER,'
      '                           NEW.NO_ORDER);'
      '    END if;                                                 '
      '  END if;'
      ' '
      
        '  if (NEW.DS_ORDER <> '#39'D'#39') AND (NEW.QTY_ORDER > 0) AND (NEW.NO_S' +
        'TEP = 0) then'
      '    INSERT INTO SL_ORDER_HIST(CD_STORE,'
      '                              NO_TABLE,'
      '                              SEQ,'
      '                              DS_ORDER,'
      '                              NO_POS,'
      '                              CD_MENU,'
      '                              QTY_ORDER,'
      '                              DT_ORDER,'
      '                              ORDER_REF,'
      '                              NO_ORDER)'
      '                      VALUES(NEW.CD_STORE,'
      '                             NEW.NO_TABLE,'
      '                             (SELECT Ifnull(MAX(SEQ),0)+1'
      '                                FROM SL_ORDER_HIST s'
      '                               WHERE CD_STORE  = NEW.CD_STORE'
      '                                 AND NO_TABLE  = NEW.NO_TABLE),'
      
        '                             case when NEW.YN_LETSORDER = '#39'Y'#39' th' +
        'en '#39'L'#39' ELSE '#39'P'#39' END,'
      '                             NEW.NO_POS,'
      '                             NEW.CD_MENU,'
      '                             NEW.QTY_ORDER,'
      '                             NOW(),'
      
        '                             CONCAT(NEW.DS_ORDER,'#39'|'#39',CAST(NEW.SE' +
        'Q AS CHAR)),'
      '                             NEW.NO_ORDER);              '
      '  END if;'
      
        '  INSERT INTO TEMP_SQL(SQL_TEXT) VALUES(CONCAT('#39'Call `SET_SOLDOU' +
        'T`('#39#39#39',NEW.CD_STORE,'#39#39#39','#39#39#39#39','#39#39#39',NEW.CD_MENU,'#39#39#39')'#39'));'
      'END//'
      'DELIMITER ;'
      'SET SQL_MODE=@OLDTMP_SQL_MODE;'
      ''
      '-- '#53944#47532#44144' orangepos.TR_SL_ORDER_D_UPDATE '#44396#51312' '#45236#48372#45236#44592
      'DROP TRIGGER IF EXISTS `TR_SL_ORDER_D_UPDATE`;'
      
        'SET @OLDTMP_SQL_MODE=@@SQL_MODE, SQL_MODE='#39'NO_AUTO_CREATE_USER,N' +
        'O_ENGINE_SUBSTITUTION'#39';'
      'DELIMITER //'
      
        'CREATE TRIGGER `TR_SL_ORDER_D_UPDATE` BEFORE UPDATE ON `sl_order' +
        '_d` FOR EACH ROW trigger_body:'
      'BEGIN'
      '  DECLARE _OPTION9    VARCHAR(1);'
      '  DECLARE _GROUP_SEQ  INT;'
      '  '
      
        '  if (OLD.CD_STORE IN ('#39'9999'#39','#39'CASHTEMP'#39')) OR (NEW.CD_STORE IN (' +
        #39'9999'#39','#39'CASHTEMP'#39')) OR (OLD.DS_ORDER <> '#39'T'#39') OR (NEW.NO_TABLE = ' +
        '0) OR (OLD.NO_STEP > 0) then'
      '     leave trigger_body; '
      '  END if;'
      ''
      '  SELECT SUBSTRING(HEAD_OPTIONS, 9, 1) INTO _OPTION9'
      '    FROM MS_STORE'
      '   WHERE CD_STORE = OLD.CD_STORE;  '
      '       '
      '  SET time_zone ='#39'+9:00'#39';'
      '  if (_OPTION9 = '#39'1'#39') AND (OLD.QTY_ORDER > NEW.QTY_ORDER) then'
      '      INSERT INTO TR_ORDER(CD_STORE,'
      '                           GROUP_SEQ,'
      '                           GROUP_STEP,'
      '                           DS_ORDER,'
      '                           NO_TABLE,'
      '                           SEQ,'
      '                           NO_STEP,'
      '                           CD_MENU,'
      '                           QTY_ORDER,'
      '                           NO_ORDER)'
      '                    VALUES(OLD.CD_STORE,'
      '                           GetNextVal('#39'TR_ORDER'#39'),'
      '                           OLD.NO_STEP,'
      '                           '#39'C'#39','
      '                           OLD.NO_TABLE,'
      '                           OLD.SEQ,'
      '                           OLD.NO_STEP,'
      '                           OLD.CD_MENU,'
      '                           ABS(NEW.QTY_ORDER - OLD.QTY_ORDER),'
      '                           NEW.NO_ORDER);'
      
        '  ELSEIF  (_OPTION9 = '#39'1'#39') AND (OLD.QTY_ORDER < NEW.QTY_ORDER) t' +
        'hen '
      '    SET  _GROUP_SEQ = GetNextVal('#39'TR_ORDER'#39');'
      '    INSERT INTO TR_ORDER(CD_STORE,'
      '                           GROUP_SEQ,'
      '                           GROUP_STEP,'
      '                           DS_ORDER,'
      '                           NO_TABLE,'
      '                           SEQ,'
      '                           NO_STEP,'
      '                           CD_MENU,'
      '                           CD_MENU_SUB,'
      '                           QTY_ORDER,'
      '                           PR_ORDER,'
      '                           AMT_ORDER,'
      '                           CD_ITEMS,'
      '                           AMT_ITEM,'
      '                           DS_MENU_TYPE,'
      '                           NO_SPC,'
      '                           DC_SPC,'
      '                           DS_ORDER_TYPE,'
      '                           ORDER_DEVICE,'
      '                           NO_ORDER)'
      '                    select CD_STORE,'
      '                           _GROUP_SEQ,        '
      '                           @ROWNUM:=@ROWNUM+1, '
      '                           '#39'O'#39','
      '                           NO_TABLE,'
      '                           SEQ,'
      '                           NO_STEP,'
      '                           CD_MENU,'
      '                           CD_MENU1,'
      '                           NEW.QTY_ORDER - OLD.QTY_ORDER,'
      '                           PR_SALE,'
      
        '                           case when CD_MENU1 = '#39#39' then (PR_SALE' +
        '+PR_ITEM) * (NEW.QTY_ORDER - OLD.QTY_ORDER) ELSE 0 end,'
      '                           CD_ITEM,'
      '                           PR_ITEM,'
      '                           DS_MENU_TYPE,'
      '                           NO_SPC,'
      '                           DC_SPC,'
      '                           DS_SALE,'
      '                           NEW.YN_LETSORDER,'
      '                           NO_ORDER'
      '                     FROM SL_ORDER_D, (SELECT @ROWNUM:=0) AS R '
      '                    WHERE CD_STORE = NEW.CD_STORE'
      '                      AND NO_TABLE = NEW.NO_TABLE'
      '                      AND DS_ORDER = '#39'T'#39
      '                      AND SEQ      = NEW.SEQ;      '
      '  END if;'
      '  '
      '  if NEW.QTY_ORDER > OLD.QTY_ORDER then'
      '      INSERT INTO SL_ORDER_HIST(CD_STORE,'
      '                                NO_TABLE,'
      '                                SEQ,'
      '                                DS_ORDER,  '
      '                                NO_POS,'
      '                                CD_MENU,'
      '                                QTY_ORDER,'
      '                                DT_ORDER,'
      '                                ORDER_REF,'
      '                                NO_ORDER)'
      '                        VALUES(NEW.CD_STORE,'
      '                               NEW.NO_TABLE,'
      '                               (SELECT Ifnull(MAX(SEQ),0)+1'
      '                                  FROM SL_ORDER_HIST s'
      '                                 WHERE CD_STORE  = NEW.CD_STORE'
      
        '                                   AND NO_TABLE  = NEW.NO_TABLE)' +
        ','
      
        '                               case when NEW.YN_LETSORDER = '#39'Y'#39' ' +
        'then '#39'L'#39' ELSE '#39'P'#39' END,'
      '                               NEW.NO_POS,'
      '                               NEW.CD_MENU,'
      '                               NEW.QTY_ORDER - OLD.QTY_ORDER,'
      '                               NOW(),'
      
        '                               CONCAT(NEW.DS_ORDER,'#39'|'#39',CAST(NEW.' +
        'SEQ AS CHAR)),'
      '                               NEW.NO_ORDER);'
      '                                          '
      '    ELSE '
      '      INSERT INTO SL_ORDER_HIST(CD_STORE,'
      '                                NO_TABLE,'
      '                                SEQ,'
      '                                DS_ORDER,  '
      '                                NO_POS,'
      '                                CD_MENU,'
      '                                QTY_ORDER,'
      '                                DT_ORDER,'
      '                                ORDER_REF,'
      '                                NO_ORDER)'
      '                        VALUES(NEW.CD_STORE,'
      '                               NEW.NO_TABLE,'
      '                               (SELECT Ifnull(MAX(SEQ),0)+1'
      '                                  FROM SL_ORDER_HIST s'
      '                                 WHERE CD_STORE  = NEW.CD_STORE'
      
        '                                   AND NO_TABLE  = NEW.NO_TABLE)' +
        ','
      
        '                               case when NEW.YN_LETSORDER = '#39'Y'#39' ' +
        'then '#39'L'#39' ELSE '#39'P'#39' END,'
      '                               NEW.NO_POS,'
      '                               NEW.CD_MENU,'
      '                               NEW.QTY_ORDER - OLD.QTY_ORDER,'
      '                               NOW(),'
      
        '                               CONCAT(NEW.DS_ORDER,'#39'|'#39',CAST(NEW.' +
        'SEQ AS CHAR)),'
      '                               NEW.NO_ORDER);'
      ''
      ''
      '  END if;'
      '  '
      'END//'
      'DELIMITER ;'
      'SET SQL_MODE=@OLDTMP_SQL_MODE;'
      ''
      '-- '#53944#47532#44144' orangepos.TR_SL_POSCLOSE_DELETE '#44396#51312' '#45236#48372#45236#44592
      'DROP TRIGGER IF EXISTS `TR_SL_POSCLOSE_DELETE`;'
      
        'SET @OLDTMP_SQL_MODE=@@SQL_MODE, SQL_MODE='#39'NO_AUTO_CREATE_USER,N' +
        'O_ENGINE_SUBSTITUTION'#39';'
      'DELIMITER //'
      
        'CREATE TRIGGER `TR_SL_POSCLOSE_DELETE` AFTER DELETE ON `sl_poscl' +
        'ose` FOR EACH ROW BEGIN'
      '  DECLARE _OPTION9    VARCHAR(1);'
      '  DECLARE _MAINPOS    VARCHAR(2);'
      '  DECLARE _DS_STATUS  VARCHAR(1);'
      '  '
      '  insert into MS_UPLOAD(CD_STORE, '
      '                        NM_TABLE, '
      '                        YMD_SALE, '
      '                        PK, '
      '                        DS_STATUS,'
      '                        DT_INSERT) '
      '                values (OLD.CD_STORE, '
      '                       '#39'SL_POSCLOSE'#39', '
      '                        OLD.YMD_CLOSE, '
      '                        ConCat(OLD.YMD_CLOSE,'#39'|'#39',OLD.NO_POS),'
      '                        '#39'D'#39','
      '                        NOW())'
      '  ON DUPLICATE KEY UPDATE DT_INSERT = NOW();'
      '  '
      '  SELECT SUBSTRING(HEAD_OPTIONS, 9, 1),'
      '         MAIN_POSNO INTO _OPTION9, _MAINPOS'
      '    FROM MS_STORE'
      '   WHERE CD_STORE = OLD.CD_STORE;  '
      '   '
      '  if (_OPTION9 = '#39'1'#39') then'
      '    SELECT DS_STATUS INTO _DS_STATUS'
      '      FROM SL_POSCLOSE '
      '     WHERE CD_STORE = OLD.CD_STORE     '
      '       AND NO_POS   = _MAINPOS'
      '     ORDER BY YMD_CLOSE desc'
      '     LIMIT 1 ;'
      '     '
      '    INSERT INTO TR_ORDER(CD_STORE,'
      '                         GROUP_SEQ,'
      '                         GROUP_STEP,'
      '                         DS_ORDER,'
      '                         NO_TABLE,'
      '                         SEQ)'
      '                  VALUES(OLD.CD_STORE,'
      '                         GetNextVal('#39'TR_ORDER'#39'),            '
      '                         0,'
      
        '                         case when _DS_STATUS = '#39'O'#39' then '#39'B'#39' els' +
        'e '#39'E'#39' end,'
      '                         0,'
      '                         0);     '
      '  END if;'
      'END//'
      'DELIMITER ;'
      'SET SQL_MODE=@OLDTMP_SQL_MODE;'
      ''
      '-- '#53944#47532#44144' orangepos.TR_SL_POSCLOSE_UPDATE '#44396#51312' '#45236#48372#45236#44592
      'DROP TRIGGER IF EXISTS `TR_SL_POSCLOSE_UPDATE`;'
      
        'SET @OLDTMP_SQL_MODE=@@SQL_MODE, SQL_MODE='#39'NO_AUTO_CREATE_USER,N' +
        'O_ENGINE_SUBSTITUTION'#39';'
      'DELIMITER //'
      
        'CREATE TRIGGER `TR_SL_POSCLOSE_UPDATE` BEFORE UPDATE ON `sl_posc' +
        'lose` FOR EACH ROW BEGIN'
      '  DECLARE _OPTION9    VARCHAR(1);'
      '  DECLARE _MAINPOS    VARCHAR(2);'
      ''
      '  insert into MS_UPLOAD(CD_STORE, '
      '                        NM_TABLE, '
      '                        YMD_SALE, '
      '                        PK, '
      '                        DS_STATUS,'
      '                        DT_INSERT) '
      '                values (OLD.CD_STORE, '
      '                       '#39'SL_POSCLOSE'#39', '
      '                        OLD.YMD_CLOSE, '
      '                        ConCat(OLD.YMD_CLOSE,'#39'|'#39',OLD.NO_POS),'
      '                        '#39'D'#39','
      '                        NOW())'
      '  ON DUPLICATE KEY UPDATE DT_INSERT = NOW();'
      '  '
      '    insert into MS_UPLOAD(CD_STORE, '
      '                        NM_TABLE, '
      '                        YMD_SALE, '
      '                        PK, '
      '                        DS_STATUS,'
      '                        DT_INSERT) '
      '                values (NEW.CD_STORE, '
      '                       '#39'SL_POSCLOSE'#39', '
      '                        NEW.YMD_CLOSE, '
      '                        ConCat(NEW.YMD_CLOSE,'#39'|'#39',NEW.NO_POS),'
      '                        '#39'I'#39','
      '                        ADDDATE(NOW(), INTERVAL 1 SECOND))'
      
        '  ON DUPLICATE KEY UPDATE DT_INSERT = ADDDATE(NOW(), INTERVAL 1 ' +
        'SECOND);'
      '  '
      '  '
      '  SELECT SUBSTRING(HEAD_OPTIONS, 9, 1),'
      '         MAIN_POSNO INTO _OPTION9, _MAINPOS'
      '    FROM MS_STORE'
      '   WHERE CD_STORE = NEW.CD_STORE;  '
      '     '
      
        '  IF (_OPTION9 = '#39'1'#39') and (NEW.NO_POS = _MAINPOS) AND (OLD.DS_ST' +
        'ATUS <> NEW.DS_STATUS) then'
      '    INSERT INTO TR_ORDER(CD_STORE,'
      '                         GROUP_SEQ,'
      '                         GROUP_STEP,'
      '                         DS_ORDER,'
      '                         NO_TABLE,'
      '                         SEQ)'
      '                  VALUES(NEW.CD_STORE,'
      '                         GetNextVal('#39'TR_ORDER'#39'),            '
      '                         0,'
      
        '                         case when NEW.DS_STATUS = '#39'O'#39' then '#39'B'#39' ' +
        'else '#39'E'#39' end,'
      '                         0,'
      '                         0);'
      '  END if;    '
      ''
      '  IF (NEW.DS_STATUS = '#39'C'#39') AND (NEW.NO_POS = _MAINPOS) then'
      '    DELETE '
      '      FROM SL_ORDER_KDS   '
      '     WHERE CD_STORE = NEW.CD_STORE'
      '       AND YMD_SALE < NEW.YMD_CLOSE;'
      '       '
      '    DELETE '
      '      FROM SL_ORDER_HIST   '
      '     WHERE CD_STORE = NEW.CD_STORE'
      '       AND DATE_FORMAT(DT_ORDER, '#39'%Y%m%d'#39') < NEW.YMD_CLOSE;    '
      '  END if;  '
      'END//'
      'DELIMITER ;'
      'SET SQL_MODE=@OLDTMP_SQL_MODE;')
    Left = 608
    Top = 640
  end
end
